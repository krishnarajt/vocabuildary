# ========== App ==========
LOG_LEVEL=INFO
LOG_DIR=/app/logs
TZ=Asia/Kolkata

# Standard 5-field crontab — when the daily word fires. Evaluated in TZ above.
# Default: 09:00 every day.
SEND_WORD_CRON=0 9 * * *

# ========== Database ==========
# Fully-formed URL. Put this straight into Vault and let External Secrets
# inject it. Format:
#   postgresql+psycopg://<user>:<password>@<host>:<port>/<dbname>
# Point this at whatever Postgres you already have running.
DATABASE_URL=postgresql+psycopg://vocabuildary:replace-me@postgres-host:5432/vocabuildary

# All vocabuildary tables live under this schema so we can share a Postgres
# with other apps without collision.
DB_SCHEMA=vocabuildary

# ========== Telegram ==========
# Legacy fallback only. The UI now stores Telegram bot tokens and chat ids per
# Authentik user in the database.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ========== Book Storage ==========
# S3-compatible object storage. These names match the Just Like Clockwork
# backend so the same MinIO/S3 secret shape can be reused.
MINIO_ENDPOINT=http://your-minio-endpoint:9000
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_BUCKET=vocabuildary-books
MINIO_REGION=us-east-1
BOOK_UPLOAD_URL_EXPIRATION_SECONDS=900
BOOK_DOWNLOAD_URL_EXPIRATION_SECONDS=3600
MAX_BOOK_UPLOAD_BYTES=524288000

# ========== LLM Gateway ==========
# Public ingress of your personal LLM Gateway. Inside the cluster you can
# also use the svc DNS (e.g. http://llmgateway.llmgateway.svc.cluster.local:8000).
LLM_GATEWAY_URL=https://llmgateway.krishnarajthadesar.in
LLM_GATEWAY_API_KEY=replace-me
LLM_GATEWAY_DEFAULT_MODEL=gemini-flash-latest
# Path on the gateway that serves the native LLMGateway chat endpoint.
LLM_GATEWAY_CHAT_PATH=/api/chat

# ========== Import ==========
# Path inside the container where words.csv is read from on startup and
# by `python -m jobs.import_words`.
WORDS_CSV_PATH=/app/words.csv
